OPENAI_API_KEY=your_full_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional planning-only cost estimates. Leave blank unless you want local estimates.
OPENAI_INPUT_COST_PER_1M=
OPENAI_OUTPUT_COST_PER_1M=

# Optional live connectors. Leave blank for local outbox mode.
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SAFT

GITHUB_TOKEN=your_github_token
GITHUB_REPOSITORY=owner/repo

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Local demo signing secret. Production should use managed keys/KMS.
AI_PM_DEMO_SIGNING_SECRET=change_me_for_local_demo
